{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["es2020", "WebWorker"],
		"module": "es2022",
		"moduleResolution": "bundler",
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"esModuleInterop": true,
		// "composite": true
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		".vscode-test-web",
		".vscode-test",
		"src/**/*.test.ts",
		"src/test-preload.ts",
		"src/assess-dataset.ts",
		"src/profile-timing.ts",
		"src/capture-snapshots.ts",
		"src/import-discourse-*.ts"
	]
}
