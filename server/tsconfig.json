{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["es2020", "WebWorker"],
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"strict": true,
		"outDir": "dist",
		"rootDir": "src",
		"esModuleInterop": true
		// "composite": true
	},
	"include": ["src"],
	"exclude": ["node_modules", ".vscode-test-web", ".vscode-test", "src/**/*.test.ts", "src/test-preload.ts", "src/capture-snapshots.ts"]
}
