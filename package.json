{
  "name": "lsp-routeros-ts",
  "description": "Language Server Protocol (LSP) for MikroTik RouterOS",
  "author": "AmmØ",
  "license": "MIT",
  "version": "0.3.6",
  "publisher": "TIKOCI",
  "categories": [
    "Programming Languages",
    "Themes",
    "Formatters",
    "Testing"
  ],
  "displayName": "RouterOS LSP",
  "icon": "icon.png",
  "keywords": [
    "routeros",
    "mikrotik",
    "lsp",
    "rsc",
    "tikoci",
    "neovim",
    "langserver"
  ],
  "preview": true,
  "pricing": "Free",
  "sponsor": {
    "url": "https://coff.ee/amm0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tikoci/lsp-routeros-ts.git"
  },
  "bugs": {
    "url": "https://github.com/tikoci/lsp-routeros-ts/issues"
  },
  "qna": "https://github.com/orgs/tikoci/discussions/categories/q-a",
  "homepage": "https://github.com/tikoci/lsp-routeros-ts/blob/main/README.md",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./client/out/extension.js",
  "funding": [
    "https://coff.ee/amm0"
  ],
  "contributes": {
    "semanticTokenTypes": [
      {
        "id": "none",
        "description": "Uncategorized or neutral token"
      },
      {
        "id": "dir",
        "superType": "struct",
        "description": "Directory or path component"
      },
      {
        "id": "cmd",
        "superType": "method",
        "description": "Command keyword or instruction"
      },
      {
        "id": "arg",
        "superType": "parameter",
        "description": "Argument to a command or function"
      },
      {
        "id": "varname-local",
        "superType": "variable",
        "description": "Local variable name"
      },
      {
        "id": "variable-parameter",
        "superType": "typeParameter",
        "description": "Parameter variable"
      },
      {
        "id": "variable-local",
        "superType": "variable",
        "description": "Locally scoped variable"
      },
      {
        "id": "syntax-val",
        "superType": "property",
        "description": "Syntax value or literal"
      },
      {
        "id": "varname",
        "superType": "variable",
        "description": "Generic variable name"
      },
      {
        "id": "syntax-meta",
        "superType": "operator",
        "description": "Meta-syntax construct"
      },
      {
        "id": "escaped",
        "superType": "macro",
        "description": "Escaped character or sequence"
      },
      {
        "id": "variable-global",
        "superType": "variable",
        "description": "Globally scoped variable"
      },
      {
        "id": "comment",
        "superType": "comment",
        "description": "Comment or annotation"
      },
      {
        "id": "obj-inactive",
        "superType": "modifier",
        "description": "Inactive or disabled object"
      },
      {
        "id": "syntax-obsolete",
        "superType": "modifier",
        "description": "Obsolete or deprecated syntax"
      },
      {
        "id": "variable-undefined",
        "superType": "modifier",
        "description": "Undefined variable reference"
      },
      {
        "id": "ambiguous",
        "superType": "modifier",
        "description": "Ambiguous or unclear token"
      },
      {
        "id": "syntax-old",
        "superType": "modifier",
        "description": "Old or legacy syntax"
      },
      {
        "id": "error",
        "superType": "modifier",
        "description": "Syntax or semantic error"
      },
      {
        "id": "varname-global",
        "superType": "variable",
        "description": "Global variable name"
      },
      {
        "id": "syntax-noterm",
        "description": "Missing or unterminated syntax element"
      }
    ],
    "themes": [
      {
        "label": "RouterOS LSP Default Dark",
        "uiTheme": "vs-dark",
        "path": "./vscode-routeroslsp-theme.json"
      }
    ],
    "languages": [
      {
        "id": "routeros",
        "extensions": [
          ".rsc"
        ],
        "firstLine": "^#.*RouterOS.*",
        "aliases": [
          "RouterOS",
          "routeros",
          "rsc"
        ],
        "configuration": "./client/language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "RouterOS LSP",
      "properties": {
        "routeroslsp.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "routeroslsp.baseUrl": {
          "scope": "resource",
          "type": "string",
          "default": "http://192.168.88.1",
          "description": "Set the host and protocol to connect to RouterOS.  e.g.: 'https://192.168.88.1'"
        },
        "routeroslsp.username": {
          "scope": "resource",
          "type": "string",
          "default": "lsp",
          "description": "Username to use when LSP connects to a real RouterOS device"
        },
        "routeroslsp.password": {
          "scope": "resource",
          "type": "string",
          "default": "changeme",
          "description": "Password to use when LSP connects to a real RouterOS device"
        },
        "routeroslsp.hotlock": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "[NeoVim only] Emulates RouterOS 'hotlock' for autocompletion"
        },
        "routeroslsp.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./server/out/* && rm -rf ./client/out/* && rm lsp-routeros-server* && rm *.vsix",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
    "compile": "npm run compile:client && npm run compile:server",
    "compile:client": "bun build client/src/extension.ts --outdir ./client/out --external vscode --format=cjs --target=node --sourcemap",
    "compile:server": "bun build server/src/server.ts --outdir ./server/out --format=cjs --target=node --sourcemap",
    "compile:exe": "npm run bun:exe",
    "vsix:package": "rm *.vsix && npm run compile && vsce package --no-dependencies --pre-release",
    "bun:exe": "rm -rf *.bun-build && bun build --compile ./server/src/server.ts --outfile ./lsp-routeros-server && chmod +x ./lsp-routeros-server && mkdir -p ~/.bin && cp ./lsp-routeros-server ~/.bin",
    "vsix:install": "npm run vsix:remove; npm run vsix:package && code --install-extension lsp-routeros-ts-*.vsix",
    "vsix:remove": "code --uninstall-extension tikoci.lsp-routeros-ts",
    "nvim:install": "npm run bun:exe && mkdir -p ~/.config/nvim && cp nvim-routeros-lsp-init.lua ~/.config/nvim && grep -q \"dofile(os.getenv('HOME') .. '/.config/nvim/nvim-routeros-lsp-init.lua')\" ~/.config/nvim/init.lua || echo \"dofile(os.getenv('HOME') .. '/.config/nvim/nvim-routeros-lsp-init.lua')\" >> ~/.config/nvim/init.lua",
    "watch": "npm run compile:server && npm run watch:client",
    "watch:client": "bun build client/src/extension.ts --outfile=client/out/extension.js --external vscode --format=cjs --target=node --sourcemap --watch",
    "watch:server": "bun build server/src/server.ts --outfile=server/out/server.js --format=cjs --target=node --sourcemap --watch",
    "bump:patch": "npm version patch; cd server; npm version patch; cd ../client; npm version patch; cd ..",
    "vscode:prepublish": "npm run compile",
    "ovsx:publish": "npx ovsx publish lsp-routeros-ts-*.vsix -p $OVSX_PAT",
    "vsix:publish": "npx @vscode/vsce publish --no-dependencies --pre-release -p $VSCE_PAT"
  },
  "devDependencies": {
    "@types/bun": "^1.2.16",
    "axios": "^1.9.0"
  },
  "peerDependencies": {
    "@types/axios": "^0.9.36",
    "@types/node": "^20.5.7",
    "@vscode/vsce": "^3.5.0",
    "bun": "^1.2.15"
  },
  "peerDependenciesMeta": {
    "@vscode/vsce": {
      "optional": true
    },
    "bun": {
      "optional": true
    },
    "peerDependencies": {
      "typescript": "^5"
    }
  },
  "private": true
}