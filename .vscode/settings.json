{
    // Project dictionaries: RouterOS, Bun, NeoVim, and LSP jargon regularly trip
    // cSpell, but these are intentional terms used throughout code and docs.
    "cSpell.words": [
        "augroup",
        "autocmd",
        "autocmds",
        "axios",
        "blackhole",
        "blockquotes",
        "browserify",
        "bufnr",
        "bunfig",
        "bunx",
        "changeme",
        "checkin",
        "cloc",
        "Cramer",
        "ctermfg",
        "datatypes",
        "dofile",
        "ECONNREFUSED",
        "ESOMETHING",
        "eworm",
        "getcwd",
        "getenv",
        "HOSTDOWN",
        "hotlock",
        "httpclient",
        "langserver",
        "lspconfig",
        "lspdoc",
        "lspexec",
        "luxon",
        "mikropkl",
        "mikrotik",
        "Mikrotikls",
        "mimetypes",
        "netinstall",
        "nexthops",
        "nonorm",
        "nosources",
        "noterm",
        "npmjs",
        "parseil",
        "parseIL",
        "popd",
        "productionize",
        "proplist",
        "pushd",
        "quickchr",
        "RAML",
        "restraml",
        "rextended",
        "routerlsp",
        "routeroslsp",
        "rscena",
        "scalearr",
        "scriptname",
        "shortid",
        "srcnat",
        "stdpath",
        "superlinear",
        "testpass",
        "testuser",
        "Tikbook",
        "toarray",
        "toolong",
        "tostr",
        "varname",
        "vscodeignore",
        "vscodeserver",
        "webhost",
        "wlan",
        "xattr"
    ],
    // NeoVim provides the `vim` global at runtime; tell LuaLS so it reports real
    // issues in `nvim-routeros-lsp-init.lua` instead of flagging every access.
    "Lua.diagnostics.globals": [
        "vim"
    ],
    "editor.insertSpaces": false,
	"typescript.tsc.autoDetect": "off",
	"typescript.preferences.quoteStyle": "single",
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit"
	},
	// Never auto-format on save — agents and humans apply formatting explicitly
	// via `bun run format` to avoid surprise diffs during normal editing.
	"editor.formatOnSave": false,
	"editor.defaultFormatter": "biomejs.biome"
}
