/;(evl /localname=$botToken;value=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11);(evl /localname=$chatID;value=-1001234567890);(evl /localname=$message;value=RouterOS alert: interface ether1 went down);(evl /localname=$url;value=(. https://api.telegram.org/bot $botToken /sendMessage));(evl /localname=$payload;value=(. { " chat_id " : " $chatID " , " text " : " $message " , " parse_mode " : " HTML " }));(evl /docommand=;(evl / (evl /tool/fetchhttp-data=$payload;http-method=post;output=none;url=$url) (evl /log/infomessage=Telegram notification sent));on-error=;(evl / (evl /log/errormessage=Failed to send Telegram notification)))