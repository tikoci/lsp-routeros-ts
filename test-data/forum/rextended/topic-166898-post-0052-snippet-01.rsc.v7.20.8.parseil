/;(evl /localname=$normalTime;value=(. (-> $months $dateM) /));(evl /ifcondition=(< $dateD 10);do=;(evl (evl /setname=$normalTime;value=(. $normalTime 0 (evl (evl /tostrvalue=$dateD)) /)) /);else=;(evl (evl /setname=$normalTime;value=(. $normalTime (evl (evl /tostrvalue=$dateD)) /)) /));(evl /setname=$normalTime;value=(. $normalTime (evl (evl /tostrvalue=$dateY))  ));/;(evl /ifcondition=(< $timeH 10);do=;(evl (evl /setname=$normalTime;value=(. $normalTime 0 (evl (evl /tostrvalue=$timeH)) :)) /);else=;(evl (evl /setname=$normalTime;value=(. $normalTime (evl (evl /tostrvalue=$timeH)) :)) /));(evl /ifcondition=(< $timeM 10);do=;(evl (evl /setname=$normalTime;value=(. $normalTime 0 (evl (evl /tostrvalue=$timeM)) :)) /);else=;(evl (evl /setname=$normalTime;value=(. $normalTime (evl (evl /tostrvalue=$timeM)) :)) /));(evl /ifcondition=(< $timeS 10);do=;(evl (evl /setname=$normalTime;value=(. $normalTime 0 (evl (evl /tostrvalue=$timeS)))) /);else=;(evl (evl /setname=$normalTime;value=(. $normalTime (evl (evl /tostrvalue=$timeS)))) /))