/;(evl /globaldo=;(evl / (evl /localname=$bin;value=$1) (evl /localname=$dec;value=0) (evl /localname=$mol;value=1) (evl /ifcondition=(! (~ $bin (. ^[0-1]{8} $)));do=;(evl (evl /returnvalue=0x00))) (evl /forcounter=$pos;do=;(evl / (evl /localname=$temp;value=(evl (evl /tonumvalue=(evl (evl /pickbegin=(- 8 $pos);counter=$bin;end=(+ (- 8 $pos) 1)))))) (evl /setname=$dec;value=(+ $dec (* $temp $mol))) (evl /setname=$mol;value=(* $mol 2)));from=1;to=8) (evl /localname=$hexadec;value=0) (evl /localname=$remainder;value=0) (evl /localname=$hexChars;value=0123456789ABCDEF) (evl /ifcondition=(> $dec 0);do=;(evl (evl /setname=$hexadec;value=))) (evl /whilecondition=(> $dec 0);do=;(evl / (evl /setname=$remainder;value=(% $dec 16)) (evl /setname=$dec;value=(/ (- $dec $remainder) 16)) (evl /setname=$hexadec;value=(. (evl (evl /pickbegin=$remainder;counter=$hexChars)) $hexadec)))) (evl /ifcondition=(= (evl (evl /lenvalue=$hexadec)) 1);do=;(evl (evl /setname=$hexadec;value=(. 0 $hexadec)))) (evl /returnvalue=(. 0x $hexadec)));name=$bin2hex)