/;/system/clock/;(evl /globalname=$strDate;value=(evl (evl /system/clock/getvalue-name=date)));(evl /globalname=$strTime;value=(evl (evl /system/clock/getvalue-name=time)));(evl /globalname=$intGoff;value=(evl (evl /tonumvalue=(evl (evl /system/clock/getvalue-name=gmt-offset)))));(evl /ifcondition=(> $intGoff 2147483647);do=;(evl (evl /setname=$intGoff;value=(- $intGoff 4294967296))));(evl /globalname=$arrMonths;value=apr=04;aug=08;dec=12;feb=02;jan=01;jul=07;jun=06;mar=03;may=05;nov=11;oct=10;sep=09);(evl /globalname=$intYear;value=(evl (evl /tonumvalue=(evl (evl /pickbegin=7;counter=$strDate;end=11)))));(evl /globalname=$strMonth;value=(-> $arrMonths (evl (evl /pickbegin=0;counter=$strDate;end=3))));(evl /globalname=$strDay;value=(evl (evl /pickbegin=4;counter=$strDate;end=6)));(evl /globalname=$strHour;value=(evl (evl /pickbegin=0;counter=$strTime;end=2)));(evl /globalname=$strMinute;value=(evl (evl /pickbegin=3;counter=$strTime;end=5)));(evl /globalname=$strSecond;value=(evl (evl /pickbegin=6;counter=$strTime;end=8)));(evl /globalname=$strOffsig;value=+);(evl /globalname=$strGoff;value=$intGoff);(evl /ifcondition=(< $intGoff 0);do=;(evl (evl /setname=$strOffsig;value=-) (evl /setname=$strGoff;value=(* $intGoff (- 1)))));(evl /globalname=$strHoff;value=(evl (evl /pickbegin=0;counter=(evl (evl /totimevalue=$strGoff));end=2)));(evl /globalname=$strMoff;value=(evl (evl /pickbegin=3;counter=(evl (evl /totimevalue=$strGoff));end=5)));(evl /globalname=$strISOdate;value=(. $intYear - $strMonth - $strDay T $strHour : $strMinute : $strSecond $strOffsig $strHoff : $strMoff));(evl /putmessage=(. $strDate   $strTime   $strOffsig $intGoff  converted to ISO format is  $strISOdate))