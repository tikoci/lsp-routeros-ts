/;(evl /globaldo=;(evl / (evl /localname=$float;value=(evl (evl /tonumvalue=$1))) (evl /localname=$decimalsign;value=,) (evl /localname=$sign;value=) (evl /ifcondition=(> $float 32767);do=;(evl (evl /setname=$float;value=(* (- $float 65536) (- 1))) (evl /setname=$sign;value=-))) (evl /localname=$forthousand;value=(* $float 1000)) (evl /localname=$forthousand;value=(/ $forthousand 256)) (evl /localname=$ftstring;value=(. 00 (evl (evl /tostrvalue=$forthousand)))) (evl /localname=$pickpos;value=(- (evl (evl /lenvalue=$ftstring)) 3)) (evl /localname=$decimals;value=(evl (evl /pickbegin=$pickpos;counter=$ftstring;end=(+ $pickpos (evl (evl /tonumvalue=$2)))))) (evl /localname=$celsius;value=(/ $forthousand 1000)) (evl /ifcondition=(> (evl (evl /tonumvalue=$2)) 0);do=;(evl (evl /setname=$celsius;value=(. $celsius $decimalsign $decimals)))) (evl /returnvalue=(. $sign $celsius)));name=$float2deg)