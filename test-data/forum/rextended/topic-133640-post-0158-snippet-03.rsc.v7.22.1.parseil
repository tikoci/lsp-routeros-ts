/;(evl / (evl /localname=$url;value=https://snort.org/downloads/ip-block-list) (evl /localname=$filename;value=ip_filter.blf) (evl /localname=$testresult;value=(evl (<%% $checkurl (> $checkurl);$url))) (evl /localname=$returncode;value=(-> $testresult cod)) (evl /localname=$returntext;value=(-> $testresult txt)) (evl /ifcondition=(= $returncode 200);do=;(evl / (<%% $update (> $update);url=$url));else=;(evl / (evl /ifcondition=(= $returncode 302);do=;(evl / (<%% $update (> $update);url=$returntext));else=;(evl / (evl /log/errormessage=(. Error checking  $url :  $returncode   $returntext)))))))