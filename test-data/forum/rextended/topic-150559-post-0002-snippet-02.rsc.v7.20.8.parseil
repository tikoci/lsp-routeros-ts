/;(evl /localname=$host;value=192.168.0.101);(evl /globalname=$vdsdown);(evl /globalname=$vdsstatus);(evl /localname=$checkvds;value=(evl (evl /pingaddress=$host;count=3)));(evl /ifcondition=(= $checkvds 0);do=;(evl / (evl /ifcondition=(!= $vdsstatus offline);do=;(evl (evl /log/errormessage=(. Host  $host  change status from  $vdsstatus  to offline)))) (evl /setname=$vdsstatus;value=offline) (evl /setname=$vdsdown;value=true)));(evl /ifcondition=(and (> $checkvds 0) (< $checkvds 3));do=;(evl / (evl /ifcondition=(!= $vdsstatus unstable);do=;(evl (evl /log/warningmessage=(. Host  $host  change status from  $vdsstatus  to unstable)))) (evl /setname=$vdsstatus;value=unstable) (evl /setname=$vdsdown;value=false)));(evl /ifcondition=(= $checkvds 3);do=;(evl / (evl /ifcondition=(!= $vdsstatus online);do=;(evl (evl /log/infomessage=(. Host  $host  change status from  $vdsstatus  to online)))) (evl /setname=$vdsstatus;value=online) (evl /setname=$vdsdown;value=false)))