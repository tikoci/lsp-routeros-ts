/;(evl /globaldo=;(evl / /system/clock/ (evl /localname=$strDate;value=(evl (evl /system/clock/getvalue-name=date))) (evl /localname=$strTime;value=(evl (evl /system/clock/getvalue-name=time))) (evl /localname=$arrMonths;value=apr=04;aug=08;dec=12;feb=02;jan=01;jul=07;jun=06;mar=03;may=05;nov=11;oct=10;sep=09) (evl /localname=$intYear;value=(evl (evl /tonumvalue=(evl (evl /pickbegin=7;counter=$strDate;end=11))))) (evl /localname=$strMonth;value=(-> $arrMonths (evl (evl /pickbegin=0;counter=$strDate;end=3)))) (evl /localname=$strDay;value=(evl (evl /pickbegin=4;counter=$strDate;end=6))) (evl /localname=$strHour;value=(evl (evl /pickbegin=0;counter=$strTime;end=2))) (evl /localname=$strMinute;value=(evl (evl /pickbegin=3;counter=$strTime;end=5))) (evl /localname=$strSecond;value=(evl (evl /pickbegin=6;counter=$strTime;end=8))) (evl /system/backup/savedont-encrypt=true;name=(. (evl (evl /system/identity/getvalue-name=name)) _ $intYear - $strMonth - $strDay _ $strHour $strMinute $strSecond)));name=$dobackup)