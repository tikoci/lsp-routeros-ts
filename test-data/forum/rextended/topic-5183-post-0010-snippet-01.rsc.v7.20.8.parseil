/;(evl /globaldo=;(evl / /system/clock/ (evl /localname=$vdate;value=(evl (evl /system/clock/getvalue-name=date))) (evl /localname=$vtime;value=(evl (evl /system/clock/getvalue-name=time))) (evl /localname=$vdoff;value=(evl (evl /toarrayvalue=0,4,5,7,8,10))) (evl /localname=$MM;value=(evl (evl /pickbegin=(-> $vdoff 2);counter=$vdate;end=(-> $vdoff 3)))) (evl /localname=$M;value=(evl (evl /tonumvalue=$MM))) (evl /ifcondition=(~ $vdate .../../....);do=;(evl /system/clock/ (evl /setname=$vdoff;value=(evl (evl /toarrayvalue=7,11,1,3,4,6))) (evl /setname=$M;value=(/ (evl (evl /findfrom=-1;in=xxanebarprayunulugepctovecANEBARPRAYUNULUGEPCTOVEC;key=(evl (evl /pickbegin=(-> $vdoff 2);counter=$vdate;end=(-> $vdoff 3))))) 2)) (evl /ifcondition=(> $M 12);do=;(evl (evl /setname=$M;value=(- $M 12)))) (evl /setname=$MM;value=(evl (evl /pickbegin=1;counter=(+ 100 $M);end=3))))) (evl /localname=$yyyy;value=(evl (evl /pickbegin=(-> $vdoff 0);counter=$vdate;end=(-> $vdoff 1)))) (evl /localname=$dd;value=(evl (evl /pickbegin=(-> $vdoff 4);counter=$vdate;end=(-> $vdoff 5)))) (evl /localname=$HH;value=(evl (evl /pickbegin=0;counter=$vtime;end=2))) (evl /localname=$mm;value=(evl (evl /pickbegin=3;counter=$vtime;end=5))) (evl /localname=$ss;value=(evl (evl /pickbegin=6;counter=$vtime;end=8))) (evl /returnvalue=(. $yyyy - $MM - $dd   $HH : $mm : $ss)));name=$simplercurrdatetimestr);(evl /putmessage=(evl (<%% $simplercurrdatetimestr (> $simplercurrdatetimestr))))