/;/ip/dns/;(evl /ip/dns/setservers=1.1.1.1;8.8.8.8);/ip/route/;(evl /ip/route/addcomment=A - 1.1.1.1 must be reachable only from ISP1;distance=1;dst-address=1.1.1.1/32;gateway=2.3.4.5;scope=10);(evl /ip/route/addcheck-gateway=ping;comment=B - Recursive Routing, check ping 1.1.1.1 instead of ISP IP;distance=10;gateway=1.1.1.1);(evl /ip/route/addcomment=C - ISP2 is alternative Gateway;distance=20;gateway=6.7.8.9)