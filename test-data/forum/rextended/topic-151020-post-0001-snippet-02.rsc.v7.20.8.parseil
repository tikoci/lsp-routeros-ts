/;(evl / (evl /localname=$url;value=https://www.iwik.org/ipcountry/US.cidr) (evl /localname=$filesize;value=(-> (evl (evl /tool/fetchas-value=$url;output=none;url=$url)) downloaded)) (evl /localname=$maxsize;value=64512) (evl /localname=$start;value=0) (evl /localname=$end;value=(- $maxsize 1)) (evl /localname=$partnumber;value=(/ $filesize (/ $maxsize 1024))) (evl /localname=$reminder;value=(% $filesize (/ $maxsize 1024))) (evl /ifcondition=(> $reminder 0);do=;(evl (evl /setname=$partnumber;value=(+ $partnumber 1)))) (evl /forcounter=$x;do=;(evl / (evl /tool/fetchdst-path=(. /part $x .txt);http-header-field=(. Range: bytes= $start - $end);keep-result=true;url=$url) (evl /setname=$start;value=(+ $start $maxsize)) (evl /setname=$end;value=(+ $end $maxsize)));from=1;step=1;to=$partnumber))