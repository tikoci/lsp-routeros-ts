/;(evl / (evl /localname=$sourceip;value=10.31.42.56) (evl /localname=$sourcesub;value=255.255.0.0) (evl /localname=$ip;value=(evl (evl /toipvalue=$sourceip))) (evl /localname=$submask;value=(evl (evl /toipvalue=$sourcesub))) (evl /localname=$addrspace;value=(~ $submask)) (evl /localname=$tempsub;value=(evl (evl /tonumvalue=$addrspace))) (evl /localname=$prefix;value=32) (evl /whilecondition=(> $tempsub 0);do=;(evl (evl /setname=$tempsub;value=(/ $tempsub 2)) (evl /setname=$prefix;value=(- $prefix 1)))) (evl /localname=$totip;value=(+ (evl (evl /tonumvalue=$addrspace)) 1)) (evl /localname=$network;value=(& $ip $submask)) (evl /localname=$broadcast;value=(| $ip $addrspace)) (evl /localname=$first;value=(- (+ $network 1) (/ $prefix 31))) (evl /localname=$last;value=(+ (- $broadcast 1) (/ $prefix 31))) (evl /localname=$usable;value=(+ (- $last $network) (/ $prefix 31))) (evl /putmessage=(.     Source IP:  $ip)) (evl /putmessage=(.   Source Mask:  $submask)) (evl /putmessage=(. Subnet Prefix:  $prefix)) (evl /putmessage=(. Address Space:  $addrspace)) (evl /putmessage=(.     Total IPs:  $totip)) (evl /putmessage=(.   Network* IP:  $network)) (evl /putmessage=(. Broadcast* IP:  $broadcast)) (evl /putmessage=(.     First* IP:  $first)) (evl /putmessage=(.      Last* IP:  $last)) (evl /putmessage=(.   Usable* IPs:  $usable)))