/;(evl /globaldo=;(evl / (evl /localname=$input;value=(evl (evl /tostrvalue=$1))) (evl /localname=$options;value=(evl (evl /tostrvalue=$2))) (evl /localdo=;(evl (evl /returnvalue=(evl (<%% (evl /parsevalue=(. ( " \ $1 " ))) ))));name=$hex2chr) (evl /localname=$lowerarray;value=a=A;b=B;c=C;d=D;e=E;f=F) (evl /ifcondition=(! (~ $input (. ^[0-9A-Fa-f]* $)));do=;(evl / (evl /errormessage=invalid characters: only 0-9, A-F and a-f are valid Base16 values))) (evl /ifcondition=(! (~ $options ignoreodd));do=;(evl / (evl /ifcondition=(!= (% (evl (evl /lenvalue=$input)) 2) 0);do=;(evl (evl /errormessage=Invalid length, is odd.))))) (evl /localname=$position;value=0) (evl /localname=$output;value=) (evl /localname=$work;value=) (evl /localname=$chk1;value=) (evl /localname=$chk2;value=) (evl /whilecondition=(< $position (evl (evl /lenvalue=$input)));do=;(evl / (evl /setname=$chk1;value=(evl (evl /pickbegin=$position;counter=$input;end=(+ $position 1)))) (evl /setname=$chk2;value=(evl (evl /pickbegin=(+ $position 1);counter=$input;end=(+ $position 2)))) (evl /ifcondition=(~ $chk1 [a-f]);do=;(evl (evl /setname=$chk1;value=(-> $lowerarray $chk1)))) (evl /ifcondition=(~ $chk2 [a-f]);do=;(evl (evl /setname=$chk2;value=(-> $lowerarray $chk2)))) (evl /setname=$work;value=(. $chk1 $chk2)) (evl /ifcondition=(= (evl (evl /lenvalue=$work)) 2);do=;(evl / (evl /setname=$work;value=(evl (<%% $hex2chr (> $hex2chr);$work))));else=;(evl / (evl /setname=$work;value=))) (evl /setname=$output;value=(. $output $work)) (evl /setname=$position;value=(+ $position 2)))) (evl /returnvalue=$output));name=$base16dec)