/;(evl /globalname=$isp1gateway;value=177.142.96.44);(evl /globalname=$isp2gateway;value=192.168.0.254);/ip/dns/;(evl /ip/dns/setservers=1.1.1.1;8.8.8.8);/ip/route/;(evl /ip/route/addcomment=A - 1.1.1.1 must be reachable only from ISP1;distance=1;dst-address=1.1.1.1/32;gateway=$isp1gateway;scope=10);(evl /ip/route/addcheck-gateway=ping;comment=B - Recursive Routing, check ping 1.1.1.1 instead of ISP1 IP;distance=10;gateway=1.1.1.1);(evl /ip/route/addcomment=C - ISP2 is alternative Gateway;distance=20;gateway=$isp2gateway)