/;(evl /globalname=$arrPreMonDays;value=01=0;02=31;03=59;04=90;05=120;06=151;07=181;08=212;09=243;10=273;11=304;12=334);(evl /globalname=$arrWeekDays;value=Thu;Fri;Sat;Sun;Mon;Tue;Wed);(evl /globalname=$numTotalDays;value=(/ (- $intYear 1968) 4));(evl /globalname=$bolLeapYear;value=false);(evl /ifcondition=(= (% (- $intYear 1968) 4) 0);do=;(evl (evl /setname=$bolLeapYear;value=true) (evl /setname=(-> $arrPreMonDays 01);value=-1) (evl /setname=(-> $arrPreMonDays 02);value=30)));(evl /setname=$numTotalDays;value=(+ $numTotalDays (* (- $intYear 1970) 365)));(evl /setname=$numTotalDays;value=(+ $numTotalDays (-> $arrPreMonDays $strMonth)));(evl /setname=$numTotalDays;value=(+ $numTotalDays (- (evl (evl /tonumvalue=$strDay)) 1)));(evl /globalname=$strWeekDay;value=(-> $arrWeekDays (% $numTotalDays 7)));(evl /globalname=$numTotHours;value=(+ (* $numTotalDays 24) (evl (evl /tonumvalue=$strHour))));(evl /globalname=$numTotMinutes;value=(+ (* $numTotHours 60) (evl (evl /tonumvalue=$strMinute))));(evl /globalname=$numTotSeconds;value=(- (+ (* $numTotMinutes 60) (evl (evl /tonumvalue=$strSecond))) $intGoff));(evl /putmessage=(. For  $strISOdate  UNIX time is  $numTotSeconds  the current year is a lap year: $bolLeapYear  and the Week Day is  $strWeekDay))