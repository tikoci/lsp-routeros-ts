/;(evl /localname=$vlanbytes;value=(evl (evl /convertfrom=num;to=byte-array;value=$vlanid)));(evl /localname=$lowbits;value=(-> $vlanbytes 0));(evl /localname=$highbits;value=(-> $vlanbytes 1));(evl /ifcondition=(> (evl (evl /lenvalue=$vlanbytes)) 2);do=;(evl / (evl /ifcondition=(> $vlanid 255);do=;(evl / (evl /ifcondition=(= (evl (evl /lenvalue=$vlanbytes)) 7);do=;(evl / (evl /setname=$vlanbytes;value=(, 0 $vlanbytes)))) (evl /setname=$lowbits;value=(-> $vlanbytes 1)) (evl /setname=$highbits;value=(-> $vlanbytes 0)))) /))