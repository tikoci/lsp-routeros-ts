/;(evl / (evl /putmessage=== use :convert to make a byte-array so we can get at the IP parts) (evl /localname=$vbytes;value=(evl (evl /convertfrom=num;to=byte-array;value=60))) (evl /localname=$lowbits;value=(-> $vbytes 0)) (evl /localname=$highbits;value=(-> $vbytes 1)) (evl /localname=$ipprefix;value=0.0.0) (evl /putmessage=(. 	 ... got  (evl (evl /tostrvalue=$vbytes)))) (evl /putmessage=== verify :convert is working as expected) (evl /putmessage=(. 	 HIGH:  (evl (evl /typeofvalue=(-> $vbytes 1)))   (evl (evl /lenvalue=(-> $vbytes 1)))   (-> $vbytes 1))) (evl /putmessage=(. 	 LOW:  (evl (evl /typeofvalue=(-> $vbytes 0)))   (evl (evl /lenvalue=(-> $vbytes 0)))   (-> $vbytes 0))) (evl /putmessage=(. 	 ** HIGH should be 'nothing' - if it something, thats a bug)) (evl /putmessage=== replicate SAME code in pvid2array) (evl /ifcondition=(= (evl (evl /typeofvalue=$highbits)) nothing);do=;(evl / (evl /setname=$ipprefix;value=(. 192.168. $lowbits)));else=;(evl / (evl /setname=$ipprefix;value=(. 172. (+ $lowbits 15) . $highbits)))) (evl /putmessage=(. 	 ... which gets a prefix of:  $ipprefix)) (evl /putmessage=== use DIFFERENT code in pvid2array to check instead for !num) (evl /ifcondition=(!= (evl (evl /typeofvalue=$highbits)) num);do=;(evl / (evl /setname=$ipprefix;value=(. 192.168. $lowbits)));else=;(evl / (evl /setname=$ipprefix;value=(. 172. (+ $lowbits 15) . $highbits)))) (evl /putmessage=(. 	 ... which gets a prefix of:  $ipprefix)))