/;(evl /globalname=$mywgname;value=<myWG>);(evl / (evl /localname=$wginterface;value=(evl (evl /interface/wireguard/findwhere=$name;$mtu;$listen-port;$private-key;$public-key;$running;$disabled;$comment;$.id;$.nextid;$.dead;$.about;(= $comment $mywgname);5))) (evl /localname=$wgcurport;value=(evl (evl /interface/wireguard/getnumber=$wginterface;value-name=listen-port))) (evl /log/infomessage=(. about to update WG for  $mywgname  with id  $wginterface  using port  $wgcurport)) (evl /interface/wireguard/setlisten-port=(+ $wgcurport 2);numbers=$wginterface) (evl /delaydelay-time=00:00:01) (evl /setname=$wgcurport;value=(evl (evl /interface/wireguard/getnumber=$wginterface;value-name=listen-port))) (evl /log/infomessage=(. updated WG for  $mywgname  to use NEW port:  $wgcurport)))