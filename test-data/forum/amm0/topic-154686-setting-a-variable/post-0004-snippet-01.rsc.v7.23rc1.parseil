/;(evl /globalname=$cellulardata;value=(evl (evl /interface/lte/monitoras-value=(evl (evl /interface/lte/findwhere=$default-name;$name;$mtu;$master;$advertised-mtu;$pin;$apn-profiles;$modem-init;$operator;$allow-roaming;$sms-read;$sms-protocol;$network-mode;$band;$nr-band;$running;$inactive;$disabled;$comment;$.id;$.nextid;$.dead;$.about;$running;5));numbers=(evl (evl /interface/lte/findwhere=$default-name;$name;$mtu;$master;$advertised-mtu;$pin;$apn-profiles;$modem-init;$operator;$allow-roaming;$sms-read;$sms-protocol;$network-mode;$band;$nr-band;$running;$inactive;$disabled;$comment;$.id;$.nextid;$.dead;$.about;$running;5));once=(evl (evl /interface/lte/findwhere=$default-name;$name;$mtu;$master;$advertised-mtu;$pin;$apn-profiles;$modem-init;$operator;$allow-roaming;$sms-read;$sms-protocol;$network-mode;$band;$nr-band;$running;$inactive;$disabled;$comment;$.id;$.nextid;$.dead;$.about;$running;5)))));(evl /log/infomessage=(. *LTE signal report*  CQI:   (-> $cellulardata cqi)   RSRQ:  (-> $cellulardata rsrq)   RSRP:  (-> $cellulardata rsrp)  ));(evl /globalname=$enb;value=(-> $cellulardata enb-id));(evl /globalname=$sector;value=(-> $cellulardata sector-id));(evl /globalname=$carrier;value=(-> $cellulardata current-operator));(evl /globalname=$band;value=(-> $cellulardata primary-band));(evl /globalname=$caband;value=(-> $cellulardata ca-band));(evl /putmessage=(. And, with https://cellmapper.net you can find location etc., checking ' $carrier ' for enb:  $enb  finding the sector  $sector  and/or  (-> $cellulardata phy-cellid)));(evl /putmessage=(. *LTE CA report*.  PRIMARY  $band . with  (evl (evl /lenvalue=$caband))  subcarriers  $caband))