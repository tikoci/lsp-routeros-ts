/;(evl /tool/netwatch/addcomment=scaletest;host=1.1.1.1;interval=00:00:03;type=icmp);(<%% $scalenetwatch (> $scalenetwatch);(evl (evl /tool/netwatch/findwhere=$name;$host;$type;$src-address;$interval;$timeout;$start-delay;$startup-delay;$ignore-initial-up;$ignore-initial-down;$up-script;$down-script;$test-script;$packet-interval;$packet-count;$packet-size;$ttl;$accept-icmp-time-exceeded;$early-success-detection;$early-failure-detection;$thr-max;$thr-avg;$thr-stdev;$thr-jitter;$thr-loss-percent;$thr-loss-count;$port;$thr-tcp-conn-time;$thr-http-time;$http-codes;$certificate;$check-certificate;$record-type;$dns-server;$status;$since;$done-tests;$failed-tests;$sent-count;$response-count;$loss-count;$loss-percent;$rtt-avg;$rtt-min;$rtt-max;$rtt-jitter;$rtt-stdev;$tcp-connect-time;$http-status-code;$http-resp-time;$ip;$ip6;$name-servers;$mail-servers;$disabled;$comment;$.id;$.nextid;$.dead;$.about;(= $comment scaletest);5)))