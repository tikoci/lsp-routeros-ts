/;(evl / (evl /globalname=$hex2ints) (evl /localname=$adverts;value=(evl (<%% bad command name iot (line 8 column 19) iot;bluetooth;scanners;advertisements;print;as-value))) (evl /foreachcounter=$advert;do=;(evl / (evl /localname=$bytes;value=(evl (<%% $hex2ints (> $hex2ints);(-> $advert data)))) (evl /putmessage=(. debug:  (evl (evl /tostrvalue=$bytes)))) (evl /ifcondition=(!= (-> $bytes 0) 13);do=;(evl (evl /putmessage=ERROR: 1st byte must be 13 or 0x0D))) (evl /ifcondition=(!= (-> $bytes 1) 255);do=;(evl (evl /putmessage=ERROR: 2nd byte must be FF))) (evl /localname=$syncPressed;value=(evl (evl /toboolvalue=(& (-> $bytes 6) 128)))) (evl /putmessage=(. sync pressed  $syncPressed)));in=$adverts))