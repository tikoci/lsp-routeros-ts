/;(evl / (evl /localname=$gqlurl;value=https://somewebsite/api/graphql) (evl /localname=$query;value=(. { " query " : " query accountid{accounts(id:2){entities{name}}} " })) (evl /localname=$contenttype;value=application/json) (evl /localname=$bearer;value=eyJ0e...LATI) (evl /localname=$headers;value=(. Content-Type:  $contenttype ,Authorization: Bearer  $bearer)) (evl /localname=$fetched;value=(evl (evl /tool/fetchas-value=user;http-data=$query;http-header-field=$headers;http-method=post;output=user;url=$gqlurl))) (evl /putmessage=$fetched) (evl /localname=$json;value=(-> $fetched data)) (evl /putmessage=$json) (evl /localname=$results;value=(evl (evl /deserializefrom=json;value=$json))) (evl /putmessage=$results) (evl /putmessage=(-> $results accountid)))