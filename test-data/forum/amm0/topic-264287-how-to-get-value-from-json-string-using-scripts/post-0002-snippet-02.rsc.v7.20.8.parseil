/;(evl /globaldo=;(evl / (evl /localname=$apiUrl;value=(. https://api.sunrise-sunset.org/json?lat= $latitude &lng= $longitude &date=today&formatted=0)) (evl /localname=$fetchResult;value=(evl (evl /tool/fetchas-value=user;output=user;url=$apiUrl))) (evl /localname=$jsonData;value=(-> $fetchResult data)) (evl /localname=$parsed;value=(evl (evl /deserializefrom=json;value=$jsonData))) (evl /returnvalue=$parsed));name=$getSunriseSunset)