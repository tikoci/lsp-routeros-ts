/;(evl /localname=$latitude;value=54.3520);(evl /localname=$longitude;value=18.6464);(evl /localname=$apiUrl;value=(. https://api.sunrise-sunset.org/json?lat= $latitude &lng= $longitude &date=today&formatted=0));(evl /localname=$fetchResult;value=(evl (evl /tool/fetchas-value=user;output=user;url=$apiUrl)));(evl /localname=$jsonData;value=(-> $fetchResult data));(evl /localname=$parsed;value=(evl (evl /deserializefrom=json;value=$jsonData)));(evl /localname=$sunrise;value=(-> (-> $parsed results) sunrise));(evl /localname=$sunset;value=(-> (-> $parsed results) sunset));(evl /putmessage=(. Sunrise:  $sunrise));(evl /putmessage=(. Sunset:  $sunset))