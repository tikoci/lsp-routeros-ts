/;(evl /globalname=$ztcget);(evl /setdo=;(evl / (evl /ifcondition=(= (evl (evl /typeofvalue=$apikey)) nothing);do=;(evl (evl /errormessage=apikey= must be provided))) (evl /ifcondition=(= (evl (evl /typeofvalue=$path)) nothing);do=;(evl (evl /errormessage=path= must be provided))) (evl /localname=$headers;value=(. Authorization: bearer  $apikey)) (evl /localname=$resp;value=(evl (evl /tool/fetchas-value=user;http-header-field=$headers;http-method=get;output=user;url=(. https://my.zerotier.com/api/v1 $path)))) (evl /log/infomessage=(. $ ztcget:  (-> $resp status)  path= $path  apikey-len= (evl (evl /lenvalue=$apikey)))) (evl /returnvalue=(-> $resp data)));name=$ztcget);(evl /globalname=$JSONLoads);(evl /ifcondition=(= (evl (evl /typeofvalue=$JSONLoads)) nothing);do=;(evl / (evl /tool/fetchurl=https://raw.githubusercontent.com/Winand/mikrotik-json-parser/master/JParseFunctions) (evl /importfile-name=JParseFunctions) (evl /delaydelay-time=00:00:05)));(evl /globalname=$ztclogin);(evl /setdo=;(evl / (evl /globalname=$ztcget) (evl /globalname=$JSONLoads) (evl /localname=$ztcjson;value=(evl (<%% $ztcget (> $ztcget);apikey=$apikey;path=/status))) (evl /localname=$ztcstatus;value=(evl (<%% $JSONLoads (> $JSONLoads);$ztcjson))) / (evl /ifcondition=(= (evl (evl /typeofvalue=(-> $ztcstatus user))) nil);do=;(evl / (evl /putmessage=Something is wrong.  Here the JSON what we got:) (evl /putmessage=$ztcjson) (evl /errormessage=** You may need to set the ZeroTier API Key, or its a bug. **));else=;(evl / (evl /putmessage=(. Hello  (-> (-> $ztcstatus user) displayName)  - if that's right, you can use the ZTC API!)))));name=$ztclogin);(<%% $ztclogin (> $ztclogin);apikey=PlEaSeAdDJSONsUpPoRtInROSScript7)