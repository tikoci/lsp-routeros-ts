/;(evl /globalname=$booltest;value=(evl (evl /toboolvalue=-1)));(evl /putmessage=(. booltest= $booltest  using -1));(evl /globalname=$booltest;value=(evl (evl /toboolvalue=0)));(evl /putmessage=(. booltest= $booltest  using 0));(evl /globalname=$booltest;value=(evl (evl /toboolvalue=1)));(evl /putmessage=(. booltest= $booltest  using 1));(evl /globalname=$booltest;value=(evl (evl /toboolvalue=1)));(evl /putmessage=(. booltest= $booltest  using  " 1 "  and returns typeof  (evl (evl /typeofvalue=$booltest))));(evl /globalname=$booltest;value=(evl (evl /toboolvalue=(evl (evl /tonumvalue=1)))));(evl /putmessage=(. booltest= $booltest  using [tonum  " 1 " ] and returns typeof  (evl (evl /typeofvalue=$booltest))))