/;(evl /globalname=$RNDORGINT);(evl /setdo=;(evl / (evl /localname=$lmin;value=(evl (evl /tonumvalue=$min))) (evl /localname=$lmax;value=(evl (evl /tonumvalue=$max))) (evl /localname=$lbase;value=(evl (evl /tonumvalue=$base))) (evl /localname=$lnum;value=1) (evl /localname=$lformat;value=plain) (evl /localname=$lcol;value=1) (evl /localname=$lrnd;value=new) (evl /ifcondition=(!= (evl (evl /typeofvalue=$lmin)) num);do=;(evl (evl /setname=$lmin;value=0))) (evl /ifcondition=(!= (evl (evl /typeofvalue=$lmax)) num);do=;(evl (evl /setname=$lmax;value=1000))) (evl /ifcondition=(!= (evl (evl /typeofvalue=$lbase)) num);do=;(evl (evl /setname=$lbase;value=10))) (evl /ifcondition=(! (~ (evl (evl /tostrvalue=$lbase)) 2|8|10|16));do=;(evl (evl /errormessage=Base must be 2, 8, 10, or 16))) (evl /localname=$url;value=https://www.random.org/integers/?) (evl /setname=$url;value=(. $url min= $lmin &max= $lmax &base= $lbase)) (evl /setname=$url;value=(. $url &num= $lnum &col= $lcol &format= $lformat &rnd= $lrnd)) (evl /localname=$headers;value=Content-Type: text/plain) (evl /localname=$resp;value=(evl (evl /tool/fetchas-value=user;http-header-field=$headers;output=user;url=$url))) (evl /localname=$rndasstr;value=(-> $resp data)) (evl /returnvalue=$rndasstr));name=$RNDORGINT)