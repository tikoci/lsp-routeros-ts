/;(evl /globaldo=;(evl / (evl /localname=$url;value=https://api.pushover.net/1/messages.json) (evl /localname=$headers;value=Content-Type: application/json) (evl /localname=$reqdata;value=(evl (evl /toarrayvalue=))) (evl /ifcondition=(= (evl (evl /typeofvalue=$1)) array);do=;(evl (evl /setname=$reqdata;value=$1));else=;(evl / (evl /errormessage=(. $ $0  requires an array of values to set, see https://pushover.net/api)))) (evl /localname=$json;value=(evl (evl /serializeto=json;value=$reqdata))) (evl /localname=$resp;value=(evl (evl /tool/fetchas-value=user;http-data=$json;http-header-field=$headers;output=user;url=$url))) (evl /localname=$respdata;value=(evl (evl /deserializefrom=json;value=(-> $resp data)))) (evl /ifcondition=(= (-> $respdata status) 1);do=;(evl / (evl /log/debugmessage=(. $0   (evl (evl /putmessage=(. successfully sent request  (-> $respdata request)))))));else=;(evl / (evl /log/warningmessage=(. $0  failed, got:  (evl (evl /tostrvalue=$resp)))) (evl /errormessage=$resp))));name=$npushover)