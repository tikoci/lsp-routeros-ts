/;(evl /globaldo=;(evl / (evl /interface/vlan/addinterface=$bridge;name=(. $name _VLAN);vlan-id=(evl (evl /tonumvalue=$pvid))) (evl /ip/address/addaddress=(. 10.0. $pvid .1/24);interface=(. $name _VLAN)) (evl /ip/pool/addname=(. $name _POOL);ranges=(. 10.0. $pvid .2-10.0. $pvid .254)) (evl /ip/dhcp-server/addaddress-pool=(. $name _POOL);disabled=false;interface=(. $name _VLAN);name=(. $name _DHCP)) (evl /ip/dhcp-server/network/addaddress=(. 10.0. $pvid .0/24);dns-server=$dns;gateway=(. 10.0. $pvid .1)));name=$pcvlan);(<%% $pcvlan (> $pcvlan);bridge=BR1;dns=192.168.0.1;name=BLUE;pvid=10);(<%% $pcvlan (> $pcvlan);bridge=BR1;dns=192.168.0.1;name=GREEN;pvid=20);(<%% $pcvlan (> $pcvlan);bridge=BR1;dns=192.168.0.1;name=RED;pvid=30)