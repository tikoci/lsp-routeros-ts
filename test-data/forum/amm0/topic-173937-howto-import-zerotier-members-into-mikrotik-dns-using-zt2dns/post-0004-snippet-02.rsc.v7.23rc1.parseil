/;(evl /localdo=;(evl / (evl /localname=$number;value=(evl (evl /tonumvalue=$1))) (evl /localname=$hexadec;value=0) (evl /localname=$remainder;value=0) (evl /localname=$hexChars;value=0123456789ABCDEF) (evl /ifcondition=(> $number 0);do=;(evl (evl /setname=$hexadec;value=))) (evl /whilecondition=(> $number 0);do=;(evl / (evl /setname=$remainder;value=(% $number 16)) (evl /setname=$number;value=(/ (- $number $remainder) 16)) (evl /setname=$hexadec;value=(. (evl (evl /pickbegin=$remainder;counter=$hexChars)) $hexadec)))) (evl /ifcondition=(= (evl (evl /lenvalue=$hexadec)) 1);do=;(evl (evl /setname=$hexadec;value=(. 0 $hexadec)))) (evl /returnvalue=$hexadec));name=$num2hex)