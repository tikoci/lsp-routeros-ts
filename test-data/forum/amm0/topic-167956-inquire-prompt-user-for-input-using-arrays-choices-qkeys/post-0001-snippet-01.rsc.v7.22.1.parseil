/;(<%% $INQUIRE (> $INQUIRE);action=(> (evl (evl /system/identity/setname=$0)));defval=(> (evl (evl /returnvalue=(evl (evl /system/identity/getvalue-name=name)))));key=sysid;text=Router name:;validate=(> (evl (evl /ifcondition=(~ (evl (evl /tostrvalue=$0)) (. ^[a-zA-Z0-9_ \ -]* $));do=;(evl (evl /returnvalue=true));else=;(evl (evl /returnvalue=invalid name)))));(> (evl (evl /putmessage=(. New system name is:  (-> $1 sysid)))));as-value)