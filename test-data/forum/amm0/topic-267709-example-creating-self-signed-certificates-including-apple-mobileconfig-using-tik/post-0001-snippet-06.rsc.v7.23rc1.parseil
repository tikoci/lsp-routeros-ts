/;(evl /certificate/addcommon-name=$domainname;days-valid=$certdays;digest-algorithm=$digestalgo;key-size=$certkeysize;key-usage=digital-signature;content-commitment;key-encipherment;data-encipherment;key-agreement;tls-server;tls-client;code-sign;email-protect;timestamp;ocsp-sign;name=(. $scepbase - $sysname -router);organization=$scepbase;subject-alt-name=$certserversans;unit=$sysname)