/;(evl /globalname=$vrrp-public-IP-address;value=2.2.2.2);/ip/firewall/nat/;(evl bad parameter out-ipsec-policy (line 9 column 90) /ip/firewall/nat/addaction=src-nat;chain=srcnat;comment=enabled if master;disabled=true;to-addresses=$vrrp-public-IP-address);(evl /ip/firewall/nat/addaction=masquerade;chain=srcnat;comment=defconf: masquerade;ipsec-policy=out;none;out-interface-list=;WAN);(evl /interface/vrrp/addinterface=ether1;name=vrrp-wan;on-backup=(. /ip firewall nat disable [find comment~ " if master " ] );on-master=(. /ip firewall nat enable [find comment~ " if master " ] ))