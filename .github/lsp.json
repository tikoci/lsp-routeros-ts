{
  "lspServers": {
    "routeroslsp": {
      "command": "npx",
      "args": ["--yes", "@tikoci/routeroslsp", "--stdio"],
      "fileExtensions": {
        ".rsc": "routeros",
        ".routeros": "routeros"
      },
      "requestTimeoutMs": 90000,
      "initializationOptions": {
        "routeroslsp": {
          "baseUrl": "http://REPLACE_ME_HOST:80",
          "username": "REPLACE_ME_USERNAME",
          "password": "REPLACE_ME_PASSWORD"
        }
      }
    }
  }
}
