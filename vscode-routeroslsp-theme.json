{
  "name": "RouterOS LSP Default Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "none": {
      "foreground": "#ffffff"
    },
    "dir": {
      "foreground": "#079B9B"
    },
    "cmd": {
      "foreground": "#9B009B",
      "fontStyle": "bold"
    },
    "arg": {
      "foreground": "#009C00"
    },
    "varname-local": {
      "foreground": "#079B9B"
    },
    "variable-parameter": {
      "foreground": "#079B9B"
    },
    "variable-local": {
      "foreground": "#079B9B"
    },
    "syntax-val": {
      "foreground": "#ffffff"
    },
    "varname": {
      "foreground": "#079B9B"
    },
    "syntax-meta": {
      "foreground": "#9B9C00",
      "fontStyle": "bold"
    },
    "escaped": {
      "foreground": "#07009B"
    },
    "variable-global": {
      "foreground": "#079B9B",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#D0CFCC",
      "fontStyle": "italic"
    },
    "obj-inactive": {
      "foreground": "#9B0100",
      "fontStyle": "italic"
    },
    "syntax-obsolete": {
      "foreground": "#9B0100",
      "fontStyle": "strikethrough"
    },
    "variable-undefined": {
      "foreground": "#9B0100",
      "fontStyle": "strikethrough"
    },
    "ambiguous": {
      "foreground": "#9B0100",
      "fontStyle": "underline"
    },
    "syntax-old": {
      "foreground": "#9B0100"
    },
    "error": {
      "foreground": "#9B0100",
      "fontStyle": "bold"
    },
    "varname-global": {
      "foreground": "#079B9B",
      "fontStyle": "bold"
    },
    "syntax-noterm": {
      "foreground": "#07009B",
      "fontStyle": "strikethrough"
    }
  }
}