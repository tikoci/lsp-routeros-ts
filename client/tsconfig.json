{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "incremental": true,
    "moduleResolution": "bundler",
    "allowJs": false,
    "noEmit": false,
    "moduleDetection": "force"
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"]
}
